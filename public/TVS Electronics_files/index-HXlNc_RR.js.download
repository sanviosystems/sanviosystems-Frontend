ge",n.jsx("span",{className:"hidden w-full md:block border-primary border-y"})]}),n.jsx("p",{children:"YOUR coverage under EWP is as follows:"}),n.jsx("p",{children:"The EWP shall cover Labour Cost, Parts Cost excluding PRINT HEAD and Parts logistics cost, if required."}),n.jsx("p",{children:"TVS-E may repair or replace hardware parts during the EWP coverage;"}),n.jsxs("ul",{className:"pl-5 list-disc",children:[n.jsx("li",{children:"With parts which are equivalent in performance to the Product being repaired or replaced"}),n.jsx("li",{children:"With parts which may contain remanufactured / re-engineered/ equivalent alternate part(s)"}),n.jsx("li",{children:"With performance parameters equivalent to the similar new part(s), for performing the EWP services."}),n.jsx("li",{children:"EWP covers only mechanical and electrical failures of Products that occur during normal use and does not cover its accessories like casing, Top cover, data cable, full housing etc."}),n.jsx("li",{children:"In the event of repairs or replacement of any part(s), during the EWP period, the EWP of the Product shall thereafter continue only for the balance EWP period."}),n.jsx("li",{children:"The replaced / defective spare parts shall become the property of TVS-E"}),n.jsx("li",{children:"The EWP does not include consumables and external plastic parts."}),n.jsx("li",{children:"Print head is excluded from EWP."})]})]}),n.jsxs("div",{className:"pb-20 space-y-6",children:[n.jsxs("p",{className:"flex items-center gap-3 pb-8 font-semibold uppercase text-primary md:whitespace-nowrap",children:["Support",n.jsx("span",{className:"hidden w-full md:block border-primary border-y"})]}),n.jsxs("ul",{className:"pl-5 list-disc",children:[n.jsx("li",{children:"For product breakfix, you shall contact one of TVS-E’s after-sales service helplines."}),n.jsx("li",{children:"TVS-E will register service incidence call in its CRM, based on YOUR request. YOU shall be given a reference call ticket number. Service incidence calls shall be attended & resolved on best efforts basis."}),n.jsx("li",{children:"Onsite service is available only for printers and scanners. Keyboards shall be serviced/ replaced through walk-in or carry-in service from the nearest TVS-E authorized service centers."})]})]}),n.jsxs("div",{className:"pb-20 space-y-6",children:[n.jsxs("p",{className:"flex items-center gap-3 pb-8 font-semibold uppercase text-primary md:whitespace-nowrap",children:["CANCELLATION OF EWP:",n.jsx("span",{className:"hidden w-full md:block border-primary border-y"})]}),n.jsx("p",{children:"You cannot cancel the EWP before the completion of the Extended Warranty Period. There shall be no refund of the fees paid for availing the EWP package."})]}),n.jsxs("div",{className:"pb-20 space-y-6",children:[n.jsxs("p",{className:"flex items-center gap-3 pb-8 font-semibold uppercase text-primary md:whitespace-nowrap",children:["EXCLUSIONS AND LIMITATIONS",n.jsx("span",{className:"hidden w-full md:block border-primary border-y"})]}),n.jsxs("p",{children:["The standard manufacturer’s warranty conditions will otherwise apply unaltered to this EWP subject to the Exclusions and Limitations as stated herein. The EWP service will be performed by trained engineers.",n.jsx("br",{}),"This Extended Warranty does not apply to (as determined by TVSE):"]}),n.jsxs("ul",{className:"pl-5 list-decimal",children:[n.jsx("li",{children:"Software, Applications, OS & interfacing parts"}),n.jsx("li",{children:"Use of Ribbon cartridge or defect resulting from the Electronics Board, Print head damage /failure"}),n.jsx("li",{children:"Print Head Pin breakage due to use of improper ribbons / stationeries, platen knob breakage due to improper use"}),n.jsx("li",{children:"Operation outside the published operating specifications for the Products"}),n.jsx("li",{children:"Parts found Missing / Broken / Damaged / Tampered / Lost / Theft due to YOUR negligence/misuse or resulting from the use of attachments, accessories, or alteration